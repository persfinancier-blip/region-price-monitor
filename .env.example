# Copy to .env and fill in real values. Never commit .env.

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/region_price_monitor
SCHEDULE_CRON=0 */6 * * *
MAX_CONCURRENCY=5
RETRY_LIMIT=3
QUEUE_CLAIM_BATCH=10
RETRY_BACKOFF_BASE_S=2.0
RETRY_BACKOFF_MAX_S=60.0
QUEUE_LOCK_TTL_S=600

# Proxy placeholders — real provider wired in a later phase (ADR-0005/BACKLOG).
PROXY_PROVIDER=static
PROXY_URL=
# JSON object {region_code: proxy_url}, e.g. {"msk": "http://user:pass@host:port"}
PROXY_MAP_JSON=

# Ozon collector — curl_cffi impersonation + warmed cookies (ADR-0005)
OZON_API_URL=https://www.ozon.ru/api/composer-api.bx/page/json/v2
OZON_IMPERSONATE=chrome
COOKIE_STORE_DIR=data/cookies
OZON_COOKIE_TTL_HOURS=12
