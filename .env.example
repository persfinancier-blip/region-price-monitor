# Copy to .env and fill in real values. Never commit .env.

# Storage backend (ADR-0009): `local` (default) needs no database at all — internal
# state (products/regions/runs/attempts/snapshots/queue) lives under LOCAL_STATE_DIR
# as flat files. Set to `postgres` to use the original DB-backed path instead.
STORAGE_BACKEND=local
LOCAL_STATE_DIR=data/state

# I/O adapters (ADR-0010): configurable product/region source + results sink
# (csv/xlsx/db), field-mapped through the canonical vocabulary (SPEC-panel §7).
# No file at this path => JSON source (today's import-products/import-regions
# behaviour) + no sink configured (export is a no-op). See config/io.example.json.
IO_CONFIG_PATH=config/io.json

# Postgres backend only (STORAGE_BACKEND=postgres). For docker-compose.prod.yml (run
# with `--profile postgres`), DATABASE_URL host must be the `postgres` service name,
# not localhost. POSTGRES_USER/PASSWORD/DB feed the postgres container itself and must
# match the credentials embedded in DATABASE_URL.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/region_price_monitor
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=region_price_monitor
SCHEDULE_CRON=0 */6 * * *
MAX_CONCURRENCY=5
RETRY_LIMIT=3
QUEUE_CLAIM_BATCH=10
RETRY_BACKOFF_BASE_S=2.0
RETRY_BACKOFF_MAX_S=60.0
QUEUE_LOCK_TTL_S=600

# Proxy placeholders — real provider wired in a later phase (ADR-0005/BACKLOG).
PROXY_PROVIDER=static
PROXY_URL=
# JSON object {region_code: proxy_url}, e.g. {"msk": "http://user:pass@host:port"}
PROXY_MAP_JSON=

# Proxy health / cooldown (Фаза 6.2, ADR-0007 §4) — derived from `attempts`, no new schema.
PROXY_HEALTH_ENABLED=true
PROXY_BAN_THRESHOLD=3
PROXY_HEALTH_WINDOW_S=900
PROXY_COOLDOWN_S=1800

# Anti-bot pacing (Фаза 6.2) — per-marketplace minimum interval + jitter between requests.
WB_MIN_INTERVAL_S=1.0
OZON_MIN_INTERVAL_S=2.0
REQUEST_JITTER_S=0.5

# Ozon collector — curl_cffi impersonation + warmed cookies (ADR-0005)
OZON_API_URL=https://www.ozon.ru/api/composer-api.bx/page/json/v2
OZON_IMPERSONATE=chrome
# In docker-compose.prod.yml this path is a named volume (`cookies`) mounted at
# /srv/app/data/cookies, so warmed Ozon cookies survive container restarts.
COOKIE_STORE_DIR=data/cookies
OZON_COOKIE_TTL_HOURS=12

# Observability (ADR-0007)
LOG_LEVEL=INFO
LOG_FORMAT=json
SUCCESS_RATE_THRESHOLD=0.9
ALERT_MIN_MEASURES=1
ALERTER=log
ALERT_WEBHOOK_URL=
